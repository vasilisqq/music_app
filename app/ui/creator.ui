   <string notr="true">
QWidget#MainWindow {
  background-color: white;
}
QLabel {
  color: #333;
  font-weight: 600;
  font-size: 14px;
}
QPushButton {
  background: qlineargradient(x1:0,y1:0,x2:0,y2:1, stop:0 #3f8bde, stop:1 #2968c0);
  border-radius: 10px;
  padding: 10px 20px;
  font-size: 14px;
  font-weight: bold;
  color: white;
  border: none;
  min-width: 100px;
}
QPushButton:hover {
  background: qlineargradient(x1:0,y1:0,x2:0,y2:1, stop:0 #2968c0, stop:1 #1f4a8a);
}
QPushButton:pressed {
  background: qlineargradient(x1:0,y1:0,x2:0,y2:1, stop:0 #1f4a8a, stop:1 #142d5a);
}
/* Красные кнопки для опасных действий */
QPushButton#reset_button, QPushButton#exit_button {
  background: qlineargradient(x1:0,y1:0,x2:0,y2:1, stop:0 #ff4444, stop:1 #cc0000);
}
QPushButton#reset_button:hover, QPushButton#exit_button:hover {
  background: qlineargradient(x1:0,y1:0,x2:0,y2:1, stop:0 #cc0000, stop:1 #990000);
}
QComboBox {
  border: 2px solid rgba(63, 139, 222, 0.2);
  border-radius: 8px;
  padding: 5px 10px;
  background: white;
  min-width: 120px;
  font-size: 14px;
  color: #333;
}
QComboBox:hover {
  border: 2px solid #3f8bde;
}
/* ФИКС: Читабельность выпадающего списка */
QComboBox QAbstractItemView {
  background-color: white;
  selection-background-color: #3f8bde;
  selection-color: white;
  border: 1px solid #3f8bde;
  outline: none;
}
QGraphicsView#graphicsView {
  background-color: #fcfcfc;
  border-radius: 20px;
  border: 2px solid rgba(63, 139, 222, 0.15);
}
