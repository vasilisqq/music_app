  <property name="styleSheet">
   <string notr="true">QMainWindow {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
    stop:0 #3a8dde, stop:0.5 #00c8d6, stop:1 #2faf5e);
}

/* Заголовок */
QLabel#titleLabel, QLabel#titleLabel1 {
  color: rgb(255,255,255); font-size: 36pt; font-weight: 700;
  background: rgba(255,255,255,0.2); border-radius: 20px; padding: 25px;
}

/* Поля ввода */
QLineEdit {
  padding: 15px 20px; border: none; border-radius: 15px; font-size: 18px;
  background: rgba(255,255,255,0.95); color: #333;
}
QLineEdit:focus { 
  background: rgba(255,255,255,1); 
  border: 3px solid #4facfe; 
  padding: 12px 17px; 
}

/* КНОПКА ВОЙТИ / РЕГИСТРАЦИИ */
QPushButton#authBtn, QPushButton#regBtn {
  background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #26af27, stop:1 #1a9f26);
  color: white; padding: 20px; border-radius: 20px; font-size: 22px; font-weight: 700;
  border: none;
}
QPushButton#authBtn:hover,QPushButton#regBtn:hover { 
  background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #1e8b1f, stop:1 #158015); 
}
QPushButton#authBtn:pressed, QPushButton#regBtn:pressed  { 
  background: rgb(9, 140, 12); 
}

/* ПРОЗРАЧНАЯ КНОПКА ПЕРЕКЛЮЧЕНИЯ */
QPushButton#switch, QPushButton#switch_2 {
  background: transparent; 
  color: rgb(255,255,255); 
  font-size: 16px; 
  font-weight: 600; 
  padding: 8px 15px;
  border: none; 
  border-radius: 8px; 
  text-decoration: underline;
}
QPushButton#switch:hover, QPushButton#switch_2:hover { 
  color: #4facfe;
}

/* ТЕКСТ */
QLabel#label, QLabel#label1 {
  color: rgb(255,255,255); 
  font-size: 16px; 
  font-weight: 500;
  padding: 0 10px;
}
QLabel{
  color: red; 
  font-size: 16px; 
  font-weight: 500;
  padding: 0 10px;
}

/* Контейнеры */
QWidget#widget, QWidget#widget_2 {
  margin: 0; padding: 0;
}
QHBoxLayout, QVBoxLayout {
  margin: 0; padding: 0;
}
QStackedWidget {
  background: transparent;
}</string>
