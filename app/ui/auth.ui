  <property name="styleSheet">
   <string notr="true">QMainWindow {
  background: qlineargradient(x1:0, y1:0, x2:1, y2:1,
    stop:0 #3a8dde, stop:0.5 #00c8d6, stop:1 #2faf5e);
}

/* Заголовок */
QLabel#titleLabel {
  color: rgb(255,255,255); font-size: 36pt; font-weight: 700;
  background: rgba(255,255,255,0.2); border-radius: 20px; padding: 25px;
}

/* Поля ввода */
QLineEdit {
  padding: 15px 20px; border: none; border-radius: 15px; font-size: 18px;
  background: rgba(255,255,255,0.95); color: #333;
}
QLineEdit:focus { 
  background: rgba(255,255,255,1); 
  border: 3px solid #4facfe; 
  padding: 12px 17px; 
}

/* БОЛЬШАЯ ЗЕЛЁНАЯ КНОПКА ВОЙТИ */
QPushButton#authBtn {
  background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #26af27, stop:1 #1a9f26);
  color: white; padding: 20px; border-radius: 20px; font-size: 22px; font-weight: 700;
  border: none;
}
QPushButton#authBtn:hover { 
  background: qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #1e8b1f, stop:1 #158015); 
}
QPushButton#authBtn:pressed { 
  background: rgb(9, 140, 12); 
}

/* ПРОЗРАЧНАЯ КНОПКА РЕГИСТРАЦИИ */
QPushButton#switch {
  background: transparent; 
  color: rgb(255,255,255); 
  font-size: 16px; 
  font-weight: 600; 
  padding: 8px 15px;
  border: none; 
  border-radius: 8px; 
  text-decoration: underline;
}
QPushButton#switch:hover { 
  background: rgba(255,255,255,0.2); 
  color: white; 
  text-decoration: none;
}

/* ТЕКСТ "Нет аккаунта?" */
QLabel#label {
  color: rgb(255,255,255); 
  font-size: 16px; 
  font-weight: 500;
  padding: 0 10px;
}

/* Контейнеры без лишних отступов */
QWidget#widget, QWidget#widget_2 {
  margin: 0; padding: 0;
}
QHBoxLayout, QVBoxLayout {
  margin: 0; padding: 0;
}</string>
