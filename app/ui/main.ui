}
.lessonCard {
  background: rgba(255,255,255,0.92);
  border-radius: 20px;
  padding: 15px;
}
.lessonCard QLabel {
  color: #222;
}
.lessonCard QLabel:first-child {
  font-size: 22px;
  font-weight: 700;
  color: #1e8b1f;
}
.lessonCard QPushButton {
  background: qlineargradient(x1:0,y1:0,x2:0,y2:1, stop:0 #26af27, stop:1 #1a9f26);
  border-radius: 12px;
  padding: 8px;
  font-size: 14px;
  font-weight: bold;
  color: white;
}
.lessonCard QPushButton:hover {
  background: qlineargradient(x1:0,y1:0,x2:0,y2:1, stop:0 #1e8b1f, stop:1 #158015);
}
QScrollArea {
  background: transparent;
  border: none;
}
QScrollBar:vertical {
  background: rgba(0,0,0,0.2);
  width: 10px;
  border-radius: 5px;
}
QScrollBar::handle:vertical {
  background: white;
  border-radius: 5px;
  min-height: 30px;
}
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
  height: 0px;
}
#drawerWidget QPushButton[active="true"] {
  background: rgba(63, 139, 222, 0.4);
  border-left: 4px solid #3f8bde;
