}
#drawerWidget QPushButton {
  background: rgba(63, 139, 222, 0.15);
  border-radius: 15px;
  padding: 10px;
  text-align: left;
  font-size: 16px;
  font-weight: 600;
  color: #333;
}
#drawerWidget QPushButton:hover {
  background: rgba(63, 139, 222, 0.25);
}
#drawerWidget QPushButton:pressed {
  background: rgba(63, 139, 222, 0.4);
}
