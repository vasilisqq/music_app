/* Левая панель */
QWidget#leftPanel {
  background: rgba(255,255,255,0.1);
  border-top-right-radius: 25px;
  border-bottom-right-radius: 25px;
}

/* Заголовок */
QLabel#appTitle {
  color: white; font-size: 30pt; font-weight: 700;
  padding: 40px 15px; text-align: center;
}

/* Кнопки панели */
QPushButton#profileBtn, QPushButton#settingsBtn, QPushButton#exitBtn {
  background: transparent;
  color: white;
  font-size: 18px;
  font-weight: 600;
  border: none;
  text-align: left;
  padding: 15px 25px;
}
QPushButton#profileBtn:hover, QPushButton#settingsBtn:hover, QPushButton#exitBtn:hover {
  color: #4facfe;
}

/* Центральные кнопки */
QPushButton#lessonBtn, QPushButton#practiceBtn, QPushButton#contestBtn {
  background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
    stop:0 #26af27, stop:1 #1a9f26);
  color: white; border-radius: 25px; border: none;
  font-size: 28px; font-weight: 700;
  padding: 40px; min-width: 300px;
}
QPushButton:hover {
  background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
    stop:0 #1e8b1f, stop:1 #158015);
}
QPushButton:pressed {
  background: rgb(9,140,12);
}

QLabel#subtitle {
  color: rgba(255,255,255,0.9);
  font-size: 22px;
  font-weight: 500;
}
